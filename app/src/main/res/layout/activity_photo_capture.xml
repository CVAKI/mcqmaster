<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview - full screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"/>

    <!-- Flash overlay (white flash on capture) -->
    <View
        android:id="@+id/flashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFFFF"
        android:visibility="gone"/>

    <!-- Top bar overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#88000000"
        android:padding="12dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Back"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#44FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <TextView
            android:id="@+id/tvKeyInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Key #1/1  AIza..."
            android:textColor="#44FF88"
            android:textSize="11sp"
            android:gravity="center"
            android:ellipsize="middle"
            android:singleLine="true"/>

        <Button
            android:id="@+id/btnManualCapture"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="📷 Now"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#44FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>
    </LinearLayout>

    <!-- Center countdown circle -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center">

        <!-- Outer ring -->
        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_outline"/>

        <!-- Countdown number -->
        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:text="10"
            android:textSize="64sp"
            android:textStyle="bold"
            android:textColor="#44FF88"
            android:gravity="center"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="6"/>
    </FrameLayout>

    <!-- Bottom status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#AA000000"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📸 Starting camera..."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Photos saved to DCIM/MCQMaster"
            android:textColor="#666688"
            android:textSize="11sp"
            android:gravity="center"/>
    </LinearLayout>

</FrameLayout>