<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Layer 1: Live camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Layer 2: Full-screen answer colour flash -->
    <View
        android:id="@+id/fullScreenColor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:visibility="invisible" />

    <!-- Layer 3: Question + Answer card (shown when MCQ detected) -->
    <LinearLayout
        android:id="@+id/questionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="#E8000000"
        android:padding="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:visibility="invisible">

        <!-- "QUESTION DETECTED" label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 QUESTION DETECTED"
            android:textColor="#FFAA44"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp" />

        <!-- The actual question text -->
        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="20dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#44FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- "ANSWER" label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅ ANSWER"
            android:textColor="#FFAA44"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp" />

        <!-- Answer letter + explanation side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Big coloured answer letter box -->
            <TextView
                android:id="@+id/answerLetter"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:gravity="center"
                android:text="A"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#33FFFFFF"
                android:layout_marginEnd="16dp"
                android:visibility="invisible" />

            <!-- Answer explanation text -->
            <TextView
                android:id="@+id/tvAnswerText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="#DDFFFFFF"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.3"
                android:visibility="invisible" />

        </LinearLayout>

    </LinearLayout>

    <!-- Layer 4: Status text pinned to bottom -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:text="Starting camera..."
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="#AA000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp" />

    <!-- Layer 5: Settings ⚙ button top-right -->
    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_manage"
        android:background="#AA000000"
        android:tint="#FFFFFF"
        android:padding="10dp"
        android:contentDescription="Settings" />

    <!-- Layer 6: Settings Panel (hidden by default) -->
    <LinearLayout
        android:id="@+id/settingsPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F0111111"
        android:padding="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚙ OpenRouter API Keys"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnCloseSettings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="@android:color/transparent"
                android:tint="#FFFFFF"
                android:contentDescription="Close" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvKeyCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 keys saved"
            android:textColor="#FFAA44"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvActiveKey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active: —"
            android:textColor="#44FF88"
            android:textSize="13sp"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etNewKey"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Paste OpenRouter API key..."
                android:textColorHint="#666666"
                android:textColor="#FFFFFF"
                android:background="#222222"
                android:padding="12dp"
                android:textSize="13sp"
                android:inputType="textVisiblePassword"
                android:singleLine="true"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnAddKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADD"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF6600"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="12dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:id="@+id/keysContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnClearAllKeys"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CLEAR ALL"
                android:textColor="#FFFFFF"
                android:backgroundTint="#CC2222"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnCloseSettings2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DONE"
                android:textColor="#FFFFFF"
                android:backgroundTint="#226622" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>